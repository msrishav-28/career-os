NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth.js / NextAuth (server-only)
DATABASE_URL=postgresql://user:password@host:5432/careeros
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-string

# Providers (configure at least one)
GITHUB_ID=your-github-oauth-id
GITHUB_SECRET=your-github-oauth-secret

# Email magic link provider
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=CareerOS <no-reply@example.com>
